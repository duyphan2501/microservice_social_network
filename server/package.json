{
  "name": "microshop",
  "private": true,
  "workspaces": [
    "gateway",
    "services/users",
    "services/posts",
    "services/friend"
  ],
  "scripts": {
    "dev:gateway": "npm --workspace gateway run dev",
    "dev:users": "npm --workspace services/users run dev",
    "dev:posts": "npm --workspace services/posts run dev",
    "dev:friend": "npm --workspace services/friend run dev",
    "start:gateway": "npm --workspace gateway run start",
    "start:users": "npm --workspace services/users run start",
    "start:posts": "npm --workspace services/posts run start",
    "dev:all": "concurrently -n gateway,users -c green,blue,yellow,gray \"npm run dev:gateway\" \"npm run dev:users\" \"npm run dev:posts\" \"npm run dev:friend\""
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "concurrently": "^8.2.0",
    "nodemon": "^3.1.0"
  },
  "dependencies": {
    "crypto": "^1.0.1",
    "nodemailer": "^7.0.10"
  }
}
